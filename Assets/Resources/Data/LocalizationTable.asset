    - key: save.metadata
      value: "\u540D\u79F0\uFF1A{0}\n\u573A\u666F\uFF1A{1}\n\u4FDD\u5B58\u65F6\u95F4\uFF1A{2}\n\u521B\u5EFA\u65F6\u95F4\uFF1A{3}\n\u6E38\u73A9\u65F6\u957F\uFF1A{4}"
