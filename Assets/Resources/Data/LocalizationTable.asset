    - key: save.confirm.new_title
      value: "\u5F00\u59CB\u65B0\u6E38\u620F"
    - key: save.confirm.new_message
      value: "\u5B58\u6863\u4F4D {0} \u5DF2\u6709\u6570\u636E\u3002\u8981\u8986\u76D6\u5E76\u5F00\u59CB\u65B0\u6E38\u620F\u5417\uFF1F"
    - key: save.confirm.delete_title
      value: "\u5220\u9664\u5B58\u6863"
    - key: save.confirm.delete_message
      value: "\u8981\u5220\u9664\u5B58\u6863\u4F4D {0} \u7684\u6570\u636E\u5417\uFF1F"
    - key: dialogue.village.oldman.001.0
      value: "\u4F60\u597D\uFF0C{playerName}\u3002\u4F60\u771F\u7684\u8981\u8FDB\u5165<color=red>\u7981\u5730</color>\u5417\uFF1F"
    - key: dialogue.village.oldman.001.1
      value: "\u98CE\u7A7F\u8FC7\u6751\u53E3\u7684\u6728\u724C\uFF0C\u65E7\u94C3\u53D1\u51FA\u8F7B\u8F7B\u7684\u54CD\u58F0\u3002"
    - key: dialogue.village.oldman.001.2
      value: "\u5982\u679C\u8FD9\u662F\u547D\u8FD0\u7ED9\u6211\u7684\u6D4B\u8BD5\uFF0C\u90A3\u6211\u81F3\u5C11\u8981\u786E\u8BA4\u5BF9\u8BDD\u7CFB\u7EDF\u80FD\u6B63\u5E38\u5DE5\u4F5C\u3002"
    - key: dialogue.village.oldman.001.3
      value: "\u7CFB\u7EDF\u63D0\u793A\uFF1A\u8FD9\u6BB5\u5BF9\u8BDD\u6765\u81EA
        DialogueTable\uFF0C\u53EF\u901A\u8FC7 Excel \u5BFC\u5165\u5DE5\u5177\u5237\u65B0\u3002"
    - key: dialogue.village.oldman.accept.0
      value: "\u592A\u597D\u4E86\u3002\u8BF7\u53BB\u68EE\u6797\u8FB9\u7684\u5C0F\u5C4B\u627E\u56DE\u9879\u94FE\u3002"
    - key: dialogue.village.oldman.decline.0
      value: "\u6211\u660E\u767D\u4E86\u3002\u5982\u679C\u4F60\u6539\u53D8\u4E3B\u610F\uFF0C\u53EF\u4EE5\u518D\u6765\u627E\u6211\u3002"
    - key: dialogue.village.oldman.reward.0
      value: "\u6211\u4F1A\u7ED9\u4F60 50 \u679A\u91D1\u5E01\uFF0C\u8FD8\u6709\u6751\u91CC\u7684\u901A\u884C\u8BC1\u660E\u3002"
    - key: dialogue.village.oldman.persuade.0
      value: "\u4F60\u7684\u8BDD\u8BA9\u6211\u5B89\u5FC3\u3002\u597D\u5427\uFF0C\u6211\u4F1A\u5148\u4ED8\u4E00\u534A\u62A5\u916C\u3002"
    - key: dialogue.village.oldman.progress.0
      value: "\u9879\u94FE\u5E94\u8BE5\u8FD8\u5728\u68EE\u6797\u8FB9\u7684\u5C0F\u5C4B\u9644\u8FD1\u3002\u627E\u5230\u540E\u518D\u56DE\u6765\u627E\u6211\u5427\u3002"
    - key: dialogue.village.oldman.found.0
      value: "\u4F60\u5728\u5C0F\u5C4B\u65C1\u627E\u5230\u4E86\u90A3\u6761\u65E7\u9879\u94FE\u3002\u73B0\u5728\u53EF\u4EE5\u56DE\u53BB\u4EA4\u7ED9\u6751\u957F\u3002"
    - key: dialogue.village.oldman.complete.0
      value: "\u6CA1\u9519\uFF0C\u5C31\u662F\u8FD9\u6761\u9879\u94FE\u3002\u8C22\u8C22\u4F60\uFF0C\u8FD9\u4EFD\u4EBA\u60C5\u6211\u4F1A\u8BB0\u4F4F\u3002"
    - key: dialogue.village.oldman.completed.0
      value: "\u4F60\u5DF2\u7ECF\u5E2E\u6211\u627E\u56DE\u9879\u94FE\u4E86\u3002\u5982\u679C\u9700\u8981\u6751\u91CC\u5E2E\u5FD9\uFF0C\u5C3D\u7BA1\u5F00\u53E3\u3002"
    - key: dialogue.village.oldman.001.option.accept
      value: "\u5F53\u7136\u613F\u610F"
    - key: dialogue.village.oldman.001.option.decline
      value: "\u6211\u6CA1\u7A7A"
    - key: dialogue.village.oldman.001.option.reward
      value: "\u4F60\u5148\u544A\u8BC9\u6211\u62A5\u916C"
    - key: dialogue.village.oldman.001.option.persuade
      value: "[\u9B45\u529B 5] \u8BF4\u670D\u4ED6"
    - key: dialogue.village.oldman.001.option.progress
      value: "\u6211\u8FD8\u6CA1\u627E\u5230\u9879\u94FE"
    - key: dialogue.village.oldman.001.option.find
      value: "\u6A21\u62DF\uFF1A\u5728\u5C0F\u5C4B\u627E\u5230\u9879\u94FE"
    - key: dialogue.village.oldman.001.option.turnin
      value: "\u628A\u9879\u94FE\u4EA4\u7ED9\u6751\u957F"
    - key: dialogue.village.oldman.001.option.completed
      value: "\u8BE2\u95EE\u5B8C\u6210\u540E\u7684\u53CD\u5E94"
    - key: dialogue.shopkeeper.001.0
      value: "\u6B22\u8FCE\u5149\u4E34\u3002\u4ECA\u5929\u7684\u82F9\u679C\u53EA\u8981
        <b>3</b> \u679A\u91D1\u5E01\u3002"
    - key: dialogue.shopkeeper.001.1
      value: "\u5982\u679C\u4F60\u5E26\u6765 {specialItem}\uFF0C\u6211\u53EF\u4EE5\u7ED9\u4F60\u7279\u522B\u6298\u6263\u3002"
    - key: dialogue.tutorial.save.001.0
      value: "\u7CFB\u7EDF\u63D0\u793A\uFF1A\u70B9\u51FB\u4FDD\u5B58\u6309\u94AE\u53EF\u4EE5\u5199\u5165\u5F53\u524D\u5B58\u6863\u69FD\u3002"
    - key: dialogue.tutorial.save.001.1
      value: "\u7CFB\u7EDF\u63D0\u793A\uFF1A\u8BFB\u53D6\u6309\u94AE\u4F1A\u4ECE\u5F53\u524D\u69FD\u4F4D\u6062\u590D\u6570\u636E\u3002"
    - key: dialogue.tutorial.dialogue.001.0
      value: "\u8FD9\u4E00\u6BB5\u7528\u4E8E\u6D4B\u8BD5\u81EA\u52A8\u64AD\u653E\u3001\u8DF3\u8FC7\u548C
        Ctrl \u52A0\u901F\u663E\u793A\u3002"
    - key: dialogue.tutorial.dialogue.001.1
      value: "\u5BCC\u6587\u672C\u4E5F\u53EF\u4EE5\u9010\u5B57\u663E\u793A\uFF1A<color=#66ccff>\u84DD\u8272\u63D0\u793A</color>\u3001<b>\u52A0\u7C97\u63D0\u793A</b>\u3002"
